  "sandhi_rules": [
    {
      "id": "FR_LIAISON_Z",
      "name": "z-liaison",
      "left_context": "z$",
      "right_context": "^[aeiouɛɔɑãɛ̃ɔ̃œ̃]",
      "transform": "z‿",
      "obligatory": true,
      "notes": "les amis → lez‿ami"
    },
    {
      "id": "FR_LIAISON_T",
      "name": "t-liaison",
      "left_context": "t$",
      "right_context": "^[aeiouɛɔɑãɛ̃ɔ̃œ̃]",
      "transform": "t‿",
      "obligatory": true,
      "notes": "petit ami → pətit‿ami"
    },
    {
      "id": "FR_LIAISON_N",
      "name": "n-liaison",
      "left_context": "n$",
      "right_context": "^[aeiouɛɔɑãɛ̃ɔ̃œ̃]",
      "transform": "n‿",
      "obligatory": true,
      "notes": "un ami → ɛ̃n‿ami"
    },
    {
      "id": "FR_LIAISON_R",
      "name": "r-liaison",

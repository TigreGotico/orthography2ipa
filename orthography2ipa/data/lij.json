  "allophone_rules": [
    {
      "id": "LIJ_N_VELAR_FINAL",
      "phonemes": [
        "n"
      ],
      "surface": "ŋ",
      "word_final": true,
      "notes": "Toso (1997), Grammatica del genovese: word-final orthographic ⟨n⟩ is realised as the velar nasal [ŋ] (e.g. can 'dog' → [kaŋ]). The grafia ofiçiâ writes the intervocalic velar nasal explicitly as ⟨n-⟩/⟨nn-⟩; word-finally it is unmarked but velar."
    },
    {
      "id": "LIJ_N_VELAR_ASSIM",
      "phonemes": [
        "n"
      ],
      "surface": "ŋ",
      "followed_by_phoneme": [
        "k",
        "ɡ"
      ],
      "notes": "Nasal place assimilation (Toso 1997): /n/ → [ŋ] before a velar stop."
    },
    {
      "id": "LIJ_N_LABIAL_ASSIM",
      "phonemes": [
        "n"
      ],
      "surface": "m",
      "followed_by_phoneme": [
        "p",
        "b",
        "m",
        "f"
      ],
      "notes": "Nasal place assimilation (Toso 1997): /n/ → [m] before a labial consonant."
    },
    {
      "id": "LIJ_NASAL_A",
      "phonemes": [
        "a"
      ],
      "surface": "ã",
      "followed_by_phoneme": [
        "ŋ"
      ],
      "notes": "Vowel nasalisation before the velar nasal coda (Forner 1975; Toso 1997): a → [ã] / _ŋ (lann-a 'wool' → [ˈlãŋa])."
    },
    {
      "id": "LIJ_NASAL_E",
      "phonemes": [
        "e"
      ],
      "surface": "ẽ",
      "followed_by_phoneme": [
        "ŋ"
      ],
      "notes": "Vowel nasalisation before the velar nasal coda (Forner 1975; Toso 1997)."
    },
    {
      "id": "LIJ_NASAL_I",
      "phonemes": [
        "i"
      ],
      "surface": "ĩ",
      "followed_by_phoneme": [
        "ŋ"
      ],
      "notes": "Vowel nasalisation before the velar nasal coda (Forner 1975; Toso 1997)."
    },
    {
      "id": "LIJ_NASAL_U",
      "phonemes": [
        "u"
      ],
      "surface": "ũ",
      "followed_by_phoneme": [
        "ŋ"
      ],
      "notes": "Vowel nasalisation before the velar nasal coda (Forner 1975; Toso 1997): orthographic ⟨o⟩ = /u/ nasalises to [ũ] before [ŋ]."
    },
    {
      "id": "LIJ_NASAL_Y",
      "phonemes": [
        "y"
      ],
      "surface": "ỹ",
      "followed_by_phoneme": [
        "ŋ"
      ],
      "notes": "Vowel nasalisation before the velar nasal coda (Forner 1975; Toso 1997): orthographic ⟨u⟩ = /y/ nasalises to [ỹ] before [ŋ]."
    },
    {
      "id": "LIJ_NASAL_O",

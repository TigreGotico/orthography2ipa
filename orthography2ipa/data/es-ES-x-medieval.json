  "ancestors": [
    {
      "code": "la-x-hispania",
      "role": "parent",
      "weight": 0.78,
      "notes": "Hispanic Vulgar Latin: primary descent. Castilian emerged in the eastern Cantabrian foothills (~9th c. CE) as the vernacular of the County of Castile, then expanded rapidly southward with the Reconquista."
    },
    {
      "code": "xce",
      "role": "substrate",
      "weight": 0.04,
      "notes": "Celtiberian substrate: the Celtic-speaking Arevaci, Pelendones, and Celtiberi of the central meseta. Likely source of some phonotactic patterns and vocabulary."
    },
    {
      "code": "xaq",
      "role": "substrate",
      "weight": 0.03,
      "notes": "Basque/Aquitanian substrate: strong in northern Castile (La Rioja, Burgos, Álava). The F→H→∅ change (hijo < FILIU) is widely attributed to Basque substrate influence, as Basque lacks /f/ natively."
    },
    {
      "code": "got",
      "role": "superstrate",
      "weight": 0.05,
      "notes": "Visigothic superstrate: the Visigoths ruled Hispania 418–711 CE. ~300 Germanic loanwords (guerra, guardar, robar, blanco, orgullo); possible influence on stress patterns."
    },
    {
      "code": "xaa",
      "role": "adstrate",
      "weight": 0.07,
      "notes": "Andalusi Arabic: the most significant lexical adstrate in Castilian, with ~4,000 Arabic loanwords — the highest density of any European language. Includes: algebra, alcohol, aceite, almohada, azúcar, cifra, ojalá, hasta. Phonological influence on the uvular/velar fricative /x/ (jota) is debated."
    },
    {
      "code": "mxi",
      "role": "adstrate",
      "weight": 0.03,
      "notes": "Mozarabic: the Ibero-Romance of the Christian communities in al-Andalus. Absorbed into Castilian through the Reconquista resettlement of the meseta and Andalusia."
    }
  ],
  "notes": "The earliest, longest, and most famous literary composition in Old Spanish is the Cantar de mio Cid (c. 1140–1207)",
